FEISHU_PROVIDER=feishu
FEISHU_BASE_URL=https://open.feishu.cn
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Optional: use a pre-provisioned token instead of app id/secret during local tests.
FEISHU_TENANT_ACCESS_TOKEN=
